PLUGIN_DIR="$CONFIG_DIR/plugins"
SPACE_MODE="${SPACE_MODE:-native}" # native | aerospace

sketchybar --bar position=top height=32 blur_radius=100 color=0xff000000 padding_left=5 padding_right=5

default=(
  padding_left=5
  padding_right=5
  icon.font="Hack Nerd Font:Normal:16.0"
  label.font="SF Compact:Normal:14.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

if [ "$SPACE_MODE" = "aerospace" ]; then
  sketchybar --add event aerospace_workspace_change

  for sid in $(aerospace list-workspaces --all); do
    sketchybar --add item space.$sid left \
      --subscribe space.$sid aerospace_workspace_change \
      --set space.$sid \
      background.color=0x44ffffff \
      background.corner_radius=5 \
      background.height=20 \
      background.drawing=off \
      icon.font="sketchybar-app-font:Regular:16.0" \
      label="$sid" \
      label.align=center \
      label.padding_left=4 \
      label.padding_right=6 \
      icon.drawing=off \
      icon.padding_left=6 \
      icon.padding_right=0 \
      label.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$CONFIG_DIR/plugins/aerospace.sh $sid"
  done
else
  SPACE_COUNT=$(
    defaults read com.apple.spaces SpacesDisplayConfiguration 2>/dev/null \
      | awk '/uuid = / { gsub(/[;"]/,"", $3); print $3 }' \
      | sort -u \
      | wc -l \
      | tr -d ' '
  )

  if [ -z "$SPACE_COUNT" ] || [ "$SPACE_COUNT" -lt 1 ]; then
    SPACE_COUNT=1
  fi

  for sid in $(seq 1 "$SPACE_COUNT"); do
    sketchybar --add space space."$sid" left \
      --set space."$sid" \
      space="$sid" \
      icon="$sid" \
      icon.padding_left=8 \
      icon.padding_right=8 \
      label.drawing=off \
      background.color=0x44ffffff \
      background.corner_radius=5 \
      background.height=20 \
      script="$PLUGIN_DIR/space.sh"
  done
fi

##### Adding Center Items #####
sketchybar --add item front_app center \
           --set front_app icon.font="sketchybar-app-font:Regular:16.0" script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

##### Adding Right Items #####
sketchybar --add item clock right \
           --set clock update_freq=10 script="$PLUGIN_DIR/clock.sh" \
           --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change \
           --add item battery right \
           --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change \
           --add item memory right \
           --set memory update_freq=10 script="$PLUGIN_DIR/memory.sh" \
           --add item temperature right \
           --set temperature update_freq=10 script="$PLUGIN_DIR/temperature.sh" \
           --add item cpu right \
           --set cpu update_freq=5 script="$PLUGIN_DIR/cpu.sh" \
           --add item network right \
           --set network update_freq=2 script="$PLUGIN_DIR/network.sh" \
           --add item progress right \
           --set progress update_freq=10 \
                          icon=󰚗 \
                          icon.color=0xffeb6f92 \
                          label.color=0xffeb6f92 \
                          script="$PLUGIN_DIR/progress.sh"

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
